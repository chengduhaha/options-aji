# OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Site URL (for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=https://optionsaji.vercel.app

# Railway Backend API (for Vercel Serverless)
RAILWAY_API_URL=http://localhost:8000
RAILWAY_API_KEY=dev-key-change-me

# Public Backend API (for browser-side fetch)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=dev-key-change-me

# FlashAlpha API (GEX data) — https://flashalpha.com
# FLASHALPHA_API_KEY=your-key-here

# twitterapi.io (X/Twitter monitoring)
# TWITTERAPI_KEY=your-key-here
