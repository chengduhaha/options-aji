# OpenRouter API Key — https://openrouter.ai/keys (also set OPENROUTER_API_KEY on the FastAPI backend)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Site URL (for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=https://options-aji.vercel.app

# ── Vercel / Next.js → FastAPI proxy (server-side only; never localhost on Vercel) ──
# Must be a URL your deployment can reach over the internet (Railway, Fly, VPS, Cloudflare Tunnel, ngrok, etc.).
# Do NOT use http://127.0.0.1 — that is the Vercel container itself, not your PC.
OPTIONS_AJI_BACKEND_URL=https://your-backend.example.com
# Optional: forwarded as X-API-Key to FastAPI when routes read OPTIONS_AJI_API_KEY
OPTIONS_AJI_API_KEY=dev-key-change-me

# Browser-visible API prefix (leave empty on Vercel so /api/* hits this Next app and proxies upstream)
# NEXT_PUBLIC_API_BASE=

# SSE Agent mode: set to 1 to stream via FastAPI /api/agent/query (requires OPTIONS_AJI_BACKEND_URL + backend OPENROUTER_API_KEY)
# NEXT_PUBLIC_USE_AGENT_SSE=1
# NEXT_PUBLIC_AGENT_BEARER=

# Legacy / dashboard widgets that still read these names:
NEXT_PUBLIC_API_KEY=dev-key-change-me

# FlashAlpha API (GEX data) — https://flashalpha.com
# FLASHALPHA_API_KEY=your-key-here

# twitterapi.io (X/Twitter monitoring)
# TWITTERAPI_KEY=your-key-here
